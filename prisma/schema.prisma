generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  forms             Form[]
  sessions          Session[]
  accounts          Account[]
  connectedAccounts ConnectedAccount[]
}

model Session {
  id           String   @id @default(cuid())
  expiresAt   DateTime
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String   @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Form {
  id          String    @id @default(cuid())
  title       String    @default("Untitled Form")
  description String    @default("")
  published   Boolean   @default(false)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  fields      Field[]
  submissions Submission[]
  channels    Channel[]
  formIntegrations FormIntegration[]
}

model Field {
  id          String   @id @default(cuid())
  formId      String
  type        String
  title       String   @default("")
  description String   @default("")
  required    Boolean  @default(false)
  order       Int
  options     String   @default("[]")
  other       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([formId])
}

model Channel {
  id           String   @id @default(cuid())
  formId       String
  name         String
  type         String   @default("other")
  trackingCode String   @unique
  createdAt    DateTime @default(now())

  form        Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([formId])
}

model Submission {
  id        String   @id @default(cuid())
  formId    String
  channelId String?
  respondentEmail String?
  createdAt DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id])
  answers Answer[]

  @@index([formId])
  @@index([channelId])
}

model Answer {
  id           String @id @default(cuid())
  submissionId String
  fieldId      String
  value        String @default("")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field      Field      @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([fieldId])
}

model ConnectedAccount {
  id        String   @id @default(cuid())
  userId    String
  type      String
  label     String
  config    String   @default("{}")
  createdAt DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id])
  formIntegrations  FormIntegration[]

  @@index([userId])
}

model FormIntegration {
  id                 String   @id @default(cuid())
  formId             String
  connectedAccountId String
  enabled            Boolean  @default(true)
  autoSend           Boolean  @default(true)
  settings           String   @default("{}")
  createdAt          DateTime @default(now())

  form             Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([formId, connectedAccountId])
  @@index([formId])
}
